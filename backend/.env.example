DATABASE_URL=postgresql://user:password@localhost:5432/distillerp
# Railway alternatives also supported:
# DATABASE_PRIVATE_URL=postgresql://user:password@host:5432/database
# POSTGRES_URL=postgresql://user:password@host:5432/database
# POSTGRES_PRIVATE_URL=postgresql://user:password@host:5432/database
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_ORIGINS=http://localhost:5173
ENVIRONMENT=development
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
BACKUP_PATH=./backups
RENDER_EXTERNAL_URL=
INITIAL_SUPERADMIN_EMAIL=superadmin@distillerp.com
INITIAL_SUPERADMIN_PASSWORD=change-this-password
INITIAL_SUPERADMIN_NAME=Test Super Admin
